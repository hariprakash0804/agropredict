# Backend .env.example

# MySQL connection string (async driver)
# Format: mysql+aiomysql://user:password@host:port/database
DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/agropredict

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# data.gov.in API key (register at https://data.gov.in to get one)
DATA_GOV_IN_API_KEY=your_api_key_here

# Chronos model name for forecasting (amazon/chronos-t5-small recommended for CPU)
CHRONOS_MODEL_NAME=amazon/chronos-t5-small

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Slack webhook URL for notifications (optional, used by scheduler)
SLACK_WEBHOOK_URL=

# SMTP settings for email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=
